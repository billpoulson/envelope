# Copy this file to ".env" in the repo root. Settings load ".env" when the process cwd is the repo root
# (e.g. scripts/start.ps1 and scripts/start.sh cd there first). Real environment variables override these.
#
# Fernet key (32 url-safe base64 bytes). Generate:
#   py -3.12 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   (or: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENVELOPE_MASTER_KEY=

# Strong random string for signing browser sessions (web UI)
ENVELOPE_SESSION_SECRET=

# Database URL (SQLAlchemy async). Default is file-backed SQLite.
# Full guide: docs/database-configuration.md
# SQLite (default for local dev / single-node):
ENVELOPE_DATABASE_URL=sqlite+aiosqlite:///./data/envelope.db
# PostgreSQL (managed HA / team deployments). Requires the asyncpg driver (see requirements.txt).
# Example: postgresql+asyncpg://envelope:secret@db.internal:5432/envelope
# TLS to the server: often via asyncpg connect args or a proxy; see driver docs for ?ssl= and sslmode.
# ENVELOPE_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# Optional: set to true to allow missing ENVELOPE_SESSION_SECRET (dev only)
# ENVELOPE_DEBUG=false

# Backup/restore API and web UI (defaults: backup on, restore off)
# ENVELOPE_BACKUP_ENABLED=true
# ENVELOPE_RESTORE_ENABLED=false

# First deployment only: plaintext admin API key stored hashed in DB; remove after creating keys via UI
# ENVELOPE_INITIAL_ADMIN_KEY=

# --- Reverse proxy / gateway (optional) ---
# Trust X-Forwarded-* only from these IPs (uvicorn; default 127.0.0.1). Example Docker bridge: 172.16.0.0/12
# FORWARDED_ALLOW_IPS=127.0.0.1
# Public URL path prefix if the app is not at / (must match gateway strip + container --root-path)
# ENVELOPE_ROOT_PATH=
# Set true when users use HTTPS so browser session cookies are Secure (TLS at the gateway)
# ENVELOPE_HTTPS_COOKIES=false

# Terraform HTTP remote state at /tfstate/projects/<slug>/... (read/write project scopes). Default true.
# ENVELOPE_TERRAFORM_HTTP_STATE_ENABLED=true
# Legacy: ENVELOPE_PULUMI_STATE_ENABLED is still read if ENVELOPE_TERRAFORM_HTTP_STATE_ENABLED is unset.
